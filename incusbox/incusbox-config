#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-only
# incusbox-config: show, edit, and manage incusbox configuration.

set -euo pipefail

_lib="$(cd "$(dirname "$0")" && pwd)/lib.sh"
[ -f "${_lib}" ] || _lib="/usr/share/incusbox/lib.sh"
# shellcheck source=lib.sh disable=SC1091
. "${_lib}"

INCUSBOX_CONFIG_DIR="${INCUSBOX_CONFIG_DIR:-${HOME}/.config/incusbox}"
INCUSBOX_CONFIG_FILE="${INCUSBOX_CONFIG_FILE:-${INCUSBOX_CONFIG_DIR}/config.yaml}"

show_help() {
    cat <<EOF
incusbox config — manage incusbox configuration

Usage:
  incusbox config show
  incusbox config edit
  incusbox config init
  incusbox config path

Subcommands:
  show    Print the current config file (or defaults if none exists)
  edit    Open the config file in \$EDITOR
  init    Write a default config file
  path    Print the config file path

Config file: ${INCUSBOX_CONFIG_FILE}

Environment overrides:
  INCUSBOX_CONFIG_DIR   Config directory (default: ~/.config/incusbox)
  INCUSBOX_CONFIG_FILE  Config file path

Examples:
  incusbox config show
  incusbox config edit
  EDITOR=nano incusbox config edit
EOF
}

_default_config() {
    cat <<EOF
# incusbox configuration
# Generated by: incusbox config init

# Default Incus remote (empty = local socket)
remote: ""

# Default storage pool
storage_pool: "default"

# Default network
network: "incusbr0"

# Default image for new containers
default_image: "ubuntu/24.04"

# Backup directory
backup_dir: "${HOME}/.local/share/incusbox/backups"

# Cloud sync remote (rclone remote name)
cloud_remote: "incusbox-backups"
cloud_path: "incusbox/backups"

# Snapshot auto schedule (systemd timer format)
snapshot_schedule: "daily"

# Demo server directory
demo_dir: "${HOME}/.local/share/incusbox/demo-server"
EOF
}

cmd_show() {
    if [ -f "${INCUSBOX_CONFIG_FILE}" ]; then
        log "Config: ${INCUSBOX_CONFIG_FILE}"
        printf '\n'
        cat "${INCUSBOX_CONFIG_FILE}"
    else
        log "No config file found at ${INCUSBOX_CONFIG_FILE}"
        log "Showing defaults (run 'incusbox config init' to create):"
        printf '\n'
        _default_config
    fi
}

cmd_edit() {
    if [ ! -f "${INCUSBOX_CONFIG_FILE}" ]; then
        mkdir -p "${INCUSBOX_CONFIG_DIR}"
        _default_config > "${INCUSBOX_CONFIG_FILE}"
        log "Created default config: ${INCUSBOX_CONFIG_FILE}"
    fi
    exec "${EDITOR:-vi}" "${INCUSBOX_CONFIG_FILE}"
}

cmd_init() {
    if [ -f "${INCUSBOX_CONFIG_FILE}" ]; then
        log "Config already exists: ${INCUSBOX_CONFIG_FILE}"
        log "Edit with: incusbox config edit"
        return 0
    fi
    mkdir -p "${INCUSBOX_CONFIG_DIR}"
    _default_config > "${INCUSBOX_CONFIG_FILE}"
    ok "Config written: ${INCUSBOX_CONFIG_FILE}"
}

cmd_path() {
    printf '%s\n' "${INCUSBOX_CONFIG_FILE}"
}

[ "$#" -eq 0 ] && { show_help; exit 0; }

subcmd="$1"; shift
case "${subcmd}" in
    show)        cmd_show ;;
    edit)        cmd_edit ;;
    init)        cmd_init ;;
    path)        cmd_path ;;
    -h|--help|help) show_help ;;
    *)
        printf >&2 "incusbox-config: unknown subcommand '%s'\n" "${subcmd}"
        show_help; exit 1 ;;
esac
