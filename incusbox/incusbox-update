#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-only
# incusbox-update: check for and install incusbox updates from GitHub.

set -euo pipefail

# ── shared library ────────────────────────────────────────────────────────────
_lib="$(cd "$(dirname "$0")" && pwd)/lib.sh"
[ -f "${_lib}" ] || _lib="/usr/share/incusbox/lib.sh"
# shellcheck source=lib.sh disable=SC1091
. "${_lib}"

GITHUB_REPO="Interested-Deving-1896/incusbox"
GITHUB_API="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"

_script_dir="$(cd "$(dirname "$0")" && pwd)"
_install_root="$(cd "${_script_dir}/.." && pwd)"

# ── helpers ───────────────────────────────────────────────────────────────────

_current_version() {
    grep '^version=' "${_script_dir}/incusbox" 2>/dev/null | head -1 | cut -d'"' -f2 \
    || echo "0.0.0"
}

_version_gt() {
    local v1="${1#v}" v2="${2#v}"
    local IFS=.
    # shellcheck disable=SC2206
    local a1=($v1) a2=($v2)
    local i
    for i in 0 1 2; do
        local n1="${a1[$i]:-0}" n2="${a2[$i]:-0}"
        [ "${n1}" -gt "${n2}" ] && return 0
        [ "${n1}" -lt "${n2}" ] && return 1
    done
    return 1
}

_fetch_release_json() {
    curl --disable --silent --fail \
        -H "Accept: application/vnd.github.v3+json" \
        "${GITHUB_API}" 2>/dev/null \
    || { warn "Could not reach GitHub API"; return 1; }
}

# ── check ─────────────────────────────────────────────────────────────────────

cmd_check() {
    local current
    current=$(_current_version)
    log "Current version : v${current}"
    log "Checking GitHub for updates..."

    local release_json latest_tag latest
    release_json=$(_fetch_release_json) || {
        info "Check manually: https://github.com/${GITHUB_REPO}/releases"
        return 1
    }

    latest_tag=$(printf '%s\n' "${release_json}" | grep '"tag_name"' | head -1 \
                 | sed 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/')
    latest="${latest_tag#v}"

    [ -n "${latest}" ] || { warn "Could not determine latest version"; return 1; }
    log "Latest version  : v${latest}"

    if _version_gt "${latest}" "${current}"; then
        echo ""
        log "Update available: v${current} → v${latest}"
        echo ""
        local body
        body=$(printf '%s\n' "${release_json}" | grep '"body"' | head -1 \
               | sed 's/.*"body":[[:space:]]*"\(.*\)".*/\1/' | head -c 500 || true)
        [ -n "${body}" ] && { log "Release notes:"; printf '%s\n' "${body}" | sed 's/^/  /'; echo ""; }
        log "Update with: incusbox update install"
    else
        log "incusbox is up to date (v${current})"
    fi
}

# ── install ───────────────────────────────────────────────────────────────────

cmd_install() {
    local current
    current=$(_current_version)
    log "Current version : v${current}"
    log "Fetching latest release..."

    local release_json latest_tag latest
    release_json=$(_fetch_release_json) || die "Could not reach GitHub API"

    latest_tag=$(printf '%s\n' "${release_json}" | grep '"tag_name"' | head -1 \
                 | sed 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/')
    latest="${latest_tag#v}"
    [ -n "${latest}" ] || die "Could not determine latest version"

    if ! _version_gt "${latest}" "${current}"; then
        log "Already up to date (v${current})"
        return 0
    fi

    log "Updating: v${current} → v${latest}"
    echo ""

    local tarball_url
    tarball_url=$(printf '%s\n' "${release_json}" | grep '"tarball_url"' | head -1 \
                  | sed 's/.*"tarball_url":[[:space:]]*"\([^"]*\)".*/\1/')
    [ -n "${tarball_url}" ] || die "No tarball URL in release"

    if [ -d "${_install_root}/.git" ]; then
        log "Git repository detected — pulling latest..."
        ( cd "${_install_root}" && git fetch origin \
          && git checkout "v${latest}" 2>/dev/null \
          || git pull origin main ) || die "Git pull failed"
        log "Updated via git to v${latest}"
    else
        local tmp_dir
        tmp_dir=$(mktemp -d)
        local tmp_tar="${tmp_dir}/incusbox-${latest}.tar.gz"

        log "Downloading v${latest}..."
        curl --disable --silent --location --fail \
            --output "${tmp_tar}" "${tarball_url}" || die "Download failed"

        log "Extracting..."
        tar xzf "${tmp_tar}" -C "${tmp_dir}" --strip-components=1

        if [ -f /usr/local/bin/incusbox ] || [ -f /usr/bin/incusbox ]; then
            log "System install detected — running install script..."
            ( cd "${tmp_dir}" && bash incusbox/install ) || die "Install failed"
        else
            log "Replacing files in ${_install_root}..."
            cp -r "${tmp_dir}"/. "${_install_root}/"
        fi

        rm -rf "${tmp_dir}"
        log "Updated to v${latest}"
    fi

    local new_ver
    new_ver=$(_current_version)
    log "Verified: v${new_ver}"
}

# ── help / dispatch ───────────────────────────────────────────────────────────

show_help() {
    cat <<EOF
incusbox-update — check for and install incusbox updates

Usage:
  incusbox-update [check]     Check for a newer version (default)
  incusbox-update install     Download and install the latest version

Options:
  -h, --help    Show this help

Examples:
  incusbox update
  incusbox update check
  incusbox update install
EOF
}

subcmd="${1:-check}"; shift || true
case "${subcmd}" in
    check)           cmd_check ;;
    install|upgrade) cmd_install ;;
    -h|--help|help)  show_help ;;
    *)
        printf >&2 "incusbox-update: unknown subcommand '%s'\n" "${subcmd}"
        printf >&2 "Run 'incusbox-update --help' for usage.\n"
        exit 1 ;;
esac
