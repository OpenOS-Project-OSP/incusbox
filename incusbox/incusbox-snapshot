#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-only
# incusbox-snapshot: create, list, restore, and delete container snapshots.

set -e

# ── shared library ────────────────────────────────────────────────────────────
_lib="$(cd "$(dirname "$0")" && pwd)/lib.sh"
[ -f "${_lib}" ] || _lib="/usr/share/incusbox/lib.sh"
# shellcheck source=lib.sh disable=SC1091
. "${_lib}"

resolve_incus

show_help() {
    cat <<EOF
incusbox-snapshot — manage Incus snapshots for incusbox containers

Usage:
  incusbox-snapshot create  NAME [SNAPSHOT]
  incusbox-snapshot list    NAME
  incusbox-snapshot restore NAME SNAPSHOT
  incusbox-snapshot delete  NAME SNAPSHOT
  incusbox-snapshot auto    <set|show|disable> NAME [options]

Subcommands:
  create   Take a snapshot of container NAME. SNAPSHOT defaults to
           snap-<timestamp> when omitted.
  list     List all snapshots of container NAME.
  restore  Restore container NAME to snapshot SNAPSHOT.
  delete   Delete snapshot SNAPSHOT from container NAME.
  auto     Manage automatic snapshot schedules (delegates to
           incusbox-snapshot-auto).

Options:
  -h, --help    Show this help

Examples:
  incusbox-snapshot create  mybox
  incusbox-snapshot create  mybox before-upgrade
  incusbox-snapshot list    mybox
  incusbox-snapshot restore mybox before-upgrade
  incusbox-snapshot delete  mybox before-upgrade
  incusbox-snapshot auto set    mybox "@daily" --expiry 7d
  incusbox-snapshot auto show   mybox
  incusbox-snapshot auto disable mybox
EOF
}

# ── subcommands ───────────────────────────────────────────────────────────────

cmd_create() {
    local name="$1"
    local snap="${2:-snap-$(date +%Y%m%d-%H%M%S)}"
    [ -z "${name}" ] && { show_help; exit 1; }
    require_incus
    log "Creating snapshot '${snap}' of container '${name}' ..."
    ${INCUS} snapshot create "${name}" "${snap}"
    log "Snapshot created: ${name}/${snap}"
}

cmd_list() {
    local name="$1"
    [ -z "${name}" ] && { show_help; exit 1; }
    require_incus
    ${INCUS} info "${name}" | awk '
        /^Snapshots:/ { in_snap=1; next }
        in_snap && /^[[:space:]]/ { print }
        in_snap && /^[^[:space:]]/ { in_snap=0 }
    '
}

cmd_restore() {
    local name="$1"
    local snap="$2"
    [ -z "${name}" ] || [ -z "${snap}" ] && { show_help; exit 1; }
    require_incus
    log "Restoring '${name}' to snapshot '${snap}' ..."
    ${INCUS} snapshot restore "${name}" "${snap}"
    log "Restored: ${name} → ${snap}"
}

cmd_delete() {
    local name="$1"
    local snap="$2"
    [ -z "${name}" ] || [ -z "${snap}" ] && { show_help; exit 1; }
    require_incus
    log "Deleting snapshot '${snap}' from '${name}' ..."
    ${INCUS} snapshot delete "${name}" "${snap}"
    log "Deleted: ${name}/${snap}"
}

# ── dispatch ──────────────────────────────────────────────────────────────────

[ "$#" -eq 0 ] && { show_help; exit 0; }

subcmd="$1"; shift
case "${subcmd}" in
    create)  cmd_create  "$@" ;;
    list|ls) cmd_list    "$@" ;;
    restore) cmd_restore "$@" ;;
    delete|rm|remove) cmd_delete "$@" ;;
    auto)
        _auto_bin="$(dirname "$0")/incusbox-snapshot-auto"
        [ -x "${_auto_bin}" ] || _auto_bin="incusbox-snapshot-auto"
        exec "${_auto_bin}" "$@" ;;
    -h|--help|help) show_help ;;
    *)
        printf >&2 "incusbox-snapshot: unknown subcommand '%s'\n" "${subcmd}"
        printf >&2 "Run 'incusbox-snapshot --help' for usage.\n"
        exit 1 ;;
esac
