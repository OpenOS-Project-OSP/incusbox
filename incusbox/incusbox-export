#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-only
# incusbox-export: export an application or service from inside an incusbox
# container to the host. Adapted from distrobox-export.
#
# This script runs INSIDE the container. It creates wrapper scripts and
# .desktop entries on the host (via the bind-mounted home directory) so
# that host launchers can invoke container applications transparently.

set -e

[ -z "${USER}" ] && USER="$(id -run)"
[ -z "${HOME}" ] && HOME="$(getent passwd "${USER}" | cut -d: -f6)"

# ── detect container context ──────────────────────────────────────────────────
if [ -z "${INCUSBOX}" ] && [ ! -f /run/incusbox-ready ]; then
    printf >&2 'incusbox-export: must be run inside an incusbox container\n'
    exit 1
fi

CONTAINER_ID="${CONTAINER_ID:-$(hostname)}"

# ── defaults ──────────────────────────────────────────────────────────────────
export_app=""
export_service=""
export_bin=""
delete_export=0
export_label=""
extra_flags=""
sudo_prefix=""
verbose=0
version="0.1.0"

# Host paths (accessible via bind-mounted home)
host_apps_dir="${HOME}/.local/share/applications"
host_bin_dir="${HOME}/.local/bin"
host_systemd_dir="${HOME}/.config/systemd/user"

show_help() {
    cat <<EOF
incusbox-export version: ${version}
Run this command INSIDE an incusbox container.

Usage:
  incusbox-export --app APPLICATION
  incusbox-export --bin /path/to/binary
  incusbox-export --service SYSTEMD_SERVICE
  incusbox-export --delete --app APPLICATION

Options:
  -a, --app APP          Export a .desktop application to the host
  -b, --bin PATH         Export a binary to ~/.local/bin on the host
  -s, --service SVC      Export a systemd user service to the host
  -d, --delete           Remove a previously exported app/bin/service
      --label LABEL      Custom label suffix for the exported entry
      --extra-flags F    Extra flags to pass to the wrapper command
      --sudo             Prefix the wrapper command with sudo
  -v, --verbose          Show verbose output
  -V, --version          Show version
  -h, --help             Show this help

Examples:
  incusbox-export --app firefox
  incusbox-export --bin /usr/bin/htop
  incusbox-export --service syncthing
  incusbox-export --delete --app firefox
EOF
}

# ── argument parsing ──────────────────────────────────────────────────────────
while [ "$#" -gt 0 ]; do
    case "$1" in
        -a|--app)          export_app="$2";     shift 2 ;;
        -b|--bin)          export_bin="$2";     shift 2 ;;
        -s|--service)      export_service="$2"; shift 2 ;;
        -d|--delete)       delete_export=1;     shift ;;
        --label)           export_label="$2";   shift 2 ;;
        --extra-flags)     extra_flags="$2";    shift 2 ;;
        --sudo)            sudo_prefix="sudo "; shift ;;
        -v|--verbose)      verbose=1;           shift ;;
        -V|--version)      printf '%s\n' "${version}"; exit 0 ;;
        -h|--help)         show_help; exit 0 ;;
        *) printf >&2 'Unknown option: %s\n' "$1"; exit 1 ;;
    esac
done

log()  { printf >&2 '%s\n' "$*"; }
info() { [ "${verbose}" -eq 1 ] && printf >&2 '+ %s\n' "$*" || true; }
die()  { printf >&2 'Error: %s\n' "$*"; exit 1; }

[ -z "${export_app}" ] && [ -z "${export_bin}" ] && [ -z "${export_service}" ] && \
    { show_help; exit 1; }

# ── binary export ─────────────────────────────────────────────────────────────
export_binary() {
    bin_path="$1"
    bin_name="$(basename "${bin_path}")"
    label="${export_label:-${CONTAINER_ID}}"
    wrapper="${host_bin_dir}/${bin_name}"

    [ -x "${bin_path}" ] || die "Binary not found or not executable: ${bin_path}"

    if [ "${delete_export}" -eq 1 ]; then
        if [ -f "${wrapper}" ] && grep -q "incusbox-enter" "${wrapper}" 2>/dev/null; then
            rm -f "${wrapper}"
            log "Removed binary export: ${wrapper}"
        else
            log "No incusbox export found at ${wrapper}"
        fi
        return 0
    fi

    mkdir -p "${host_bin_dir}"

    cat > "${wrapper}" <<WRAPPER
#!/bin/sh
# Exported from incusbox container: ${CONTAINER_ID}
# Generated by incusbox-export — do not edit manually
exec incusbox enter --headless "${CONTAINER_ID}" -- ${sudo_prefix}${bin_path} ${extra_flags} "\$@"
WRAPPER
    chmod +x "${wrapper}"
    log "Exported binary: ${wrapper}"
    log "  → runs ${bin_path} inside container '${CONTAINER_ID}'"
}

# ── .desktop application export ───────────────────────────────────────────────
export_application() {
    app_name="$1"
    label="${export_label:-${CONTAINER_ID}}"

    # Find the .desktop file inside the container
    desktop_file=""
    for search_dir in \
        /usr/share/applications \
        /usr/local/share/applications \
        "${HOME}/.local/share/applications"; do
        if [ -f "${search_dir}/${app_name}.desktop" ]; then
            desktop_file="${search_dir}/${app_name}.desktop"
            break
        fi
        # Also try case-insensitive search
        found="$(find "${search_dir}" -iname "${app_name}.desktop" 2>/dev/null | head -1)"
        if [ -n "${found}" ]; then
            desktop_file="${found}"
            break
        fi
    done

    host_desktop="${host_apps_dir}/incusbox-${CONTAINER_ID}-${app_name}.desktop"

    if [ "${delete_export}" -eq 1 ]; then
        if [ -f "${host_desktop}" ]; then
            rm -f "${host_desktop}"
            log "Removed application export: ${host_desktop}"
        else
            log "No incusbox export found at ${host_desktop}"
        fi
        return 0
    fi

    [ -n "${desktop_file}" ] || die ".desktop file not found for '${app_name}'"

    mkdir -p "${host_apps_dir}"

    # Rewrite the .desktop file:
    # - Prefix Exec= lines with incusbox-enter
    # - Append container label to Name=
    # - Set StartupWMClass for window matching
    sed \
        -e "s|^Exec=\(.*\)|Exec=incusbox enter --headless ${CONTAINER_ID} -- ${sudo_prefix}\1 ${extra_flags}|" \
        -e "s|^TryExec=.*|TryExec=incusbox|" \
        -e "s|^Name=\(.*\)|Name=\1 (${label})|" \
        "${desktop_file}" > "${host_desktop}"

    # Ensure the desktop file is valid
    printf 'X-IncusBox-Container=%s\n' "${CONTAINER_ID}" >> "${host_desktop}"
    printf 'X-IncusBox-Source=%s\n' "${desktop_file}" >> "${host_desktop}"

    chmod +x "${host_desktop}" 2>/dev/null || true
    log "Exported application: ${host_desktop}"
    log "  → launches ${app_name} inside container '${CONTAINER_ID}'"

    # Update desktop database if available
    command -v update-desktop-database >/dev/null 2>&1 && \
        update-desktop-database "${host_apps_dir}" 2>/dev/null || true
}

# ── systemd service export ────────────────────────────────────────────────────
export_systemd_service() {
    svc_name="$1"
    label="${export_label:-${CONTAINER_ID}}"

    # Find the service file inside the container
    svc_file=""
    for search_dir in \
        /usr/lib/systemd/user \
        /usr/local/lib/systemd/user \
        "${HOME}/.config/systemd/user"; do
        if [ -f "${search_dir}/${svc_name}.service" ]; then
            svc_file="${search_dir}/${svc_name}.service"
            break
        fi
    done

    host_svc="${host_systemd_dir}/incusbox-${CONTAINER_ID}-${svc_name}.service"

    if [ "${delete_export}" -eq 1 ]; then
        if [ -f "${host_svc}" ]; then
            systemctl --user disable --now "incusbox-${CONTAINER_ID}-${svc_name}.service" \
                2>/dev/null || true
            rm -f "${host_svc}"
            systemctl --user daemon-reload 2>/dev/null || true
            log "Removed service export: ${host_svc}"
        else
            log "No incusbox export found at ${host_svc}"
        fi
        return 0
    fi

    [ -n "${svc_file}" ] || die "Service file not found for '${svc_name}'"

    mkdir -p "${host_systemd_dir}"

    # Rewrite the service file to run inside the container via incusbox-enter
    sed \
        -e "s|^ExecStart=\(.*\)|ExecStart=incusbox enter --headless ${CONTAINER_ID} -- \1|" \
        -e "s|^ExecStop=\(.*\)|ExecStop=incusbox enter --headless ${CONTAINER_ID} -- \1|" \
        -e "s|^Description=\(.*\)|Description=\1 [incusbox: ${label}]|" \
        "${svc_file}" > "${host_svc}"

    printf '\n[X-IncusBox]\nContainer=%s\nSource=%s\n' \
        "${CONTAINER_ID}" "${svc_file}" >> "${host_svc}"

    systemctl --user daemon-reload 2>/dev/null || true
    log "Exported service: ${host_svc}"
    log "  → enable with: systemctl --user enable --now incusbox-${CONTAINER_ID}-${svc_name}.service"
}

# ── dispatch ──────────────────────────────────────────────────────────────────
[ -z "${export_bin}" ]     || export_binary "${export_bin}"
[ -z "${export_app}" ]     || export_application "${export_app}"
[ -z "${export_service}" ] || export_systemd_service "${export_service}"
