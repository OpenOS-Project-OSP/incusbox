#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-only
# incusbox-status: show detailed status of one or all incusbox containers/VMs.

set -euo pipefail

_lib="$(cd "$(dirname "$0")" && pwd)/lib.sh"
[ -f "${_lib}" ] || _lib="/usr/share/incusbox/lib.sh"
# shellcheck source=lib.sh disable=SC1091
. "${_lib}"

resolve_incus

show_help() {
    cat <<EOF
incusbox status — show detailed status of containers/VMs

Usage:
  incusbox status [NAME] [--json] [--watch]

Arguments:
  NAME        Instance name (default: show all)

Options:
  --json      Output as JSON
  --watch     Refresh every 2 seconds (Ctrl-C to stop)
  -h, --help  Show this help

Examples:
  incusbox status
  incusbox status mybox
  incusbox status --watch
EOF
}

name=""
json_out=false
watch_mode=false

while [ "$#" -gt 0 ]; do
    case "$1" in
        --json)    json_out=true;  shift ;;
        --watch)   watch_mode=true; shift ;;
        -h|--help) show_help; exit 0 ;;
        -*) die "Unknown option: $1" ;;
        *)  name="$1"; shift ;;
    esac
done

_show_status() {
    if [ -n "${name}" ]; then
        if "${json_out}"; then
            "${INCUS_CMD}" info "${name}" --format json
        else
            "${INCUS_CMD}" info "${name}"
        fi
    else
        if "${json_out}"; then
            "${INCUS_CMD}" list --format json
        else
            "${INCUS_CMD}" list --format table \
                -c ns4tS \
                --columns "name,status,ipv4,type,snapshots"
        fi
    fi
}

if "${watch_mode}"; then
    while true; do
        clear
        printf '\033[1mincusbox status\033[0m  %s\n\n' "$(date '+%H:%M:%S')"
        _show_status || true
        sleep 2
    done
else
    _show_status
fi
