#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-only
# incusbox-build — build a custom Incus container image
#
# Launches a temporary container from a base image, runs a provisioning
# script inside it, then publishes the result as a reusable Incus image.
# The temporary container is removed after publishing.
#
# Usage:
#   incusbox build [options]
#
# Options:
#   --base IMAGE       Base Incus image (default: images:ubuntu/24.04/cloud)
#   --name NAME        Name for the published image alias (required)
#   --script PATH      Provisioning script to run inside the container
#   --packages PKG...  Packages to install (apt) before running --script
#   --profile PROFILE  Incus profile to apply to the build container
#   --storage POOL     Incus storage pool to use
#   --keep             Keep the build container after publishing (don't delete)
#   --no-publish       Build and provision but do not publish as an image
#   --description DESC Description for the published image
#   --help             Show this help
#
# Examples:
#   incusbox build --base images:ubuntu/24.04/cloud --name mybox/dev \
#       --packages "git curl vim" --script ./provision.sh
#
#   incusbox build --base images:debian/12/cloud --name mybox/server \
#       --script ./server-setup.sh --description "Pre-configured server"

set -euo pipefail

_self="$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
_dir="$(dirname "${_self}")"
_lib="${_dir}/lib.sh"
[ -f "${_lib}" ] || _lib="/usr/share/incusbox/lib.sh"
# shellcheck source=lib.sh disable=SC1091
. "${_lib}"

resolve_incus

# ── defaults ──────────────────────────────────────────────────────────────────

BASE_IMAGE="images:ubuntu/24.04/cloud"
ALIAS_NAME=""
SCRIPT_PATH=""
PACKAGES=""
PROFILE=""
STORAGE_POOL=""
KEEP=0
NO_PUBLISH=0
DESCRIPTION=""
BUILD_CT=""   # set after name is known

# ── help ──────────────────────────────────────────────────────────────────────

show_help() {
    sed -n '/^# Usage:/,/^[^#]/p' "$0" | grep '^#' | sed 's/^# \?//'
    exit 0
}

# ── argument parsing ──────────────────────────────────────────────────────────

parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            --base)        BASE_IMAGE="$2";   shift 2 ;;
            --name)        ALIAS_NAME="$2";   shift 2 ;;
            --script)      SCRIPT_PATH="$2";  shift 2 ;;
            --packages)    PACKAGES="$2";     shift 2 ;;
            --profile)     PROFILE="$2";      shift 2 ;;
            --storage)     STORAGE_POOL="$2"; shift 2 ;;
            --keep)        KEEP=1;            shift ;;
            --no-publish)  NO_PUBLISH=1;      shift ;;
            --description) DESCRIPTION="$2";  shift 2 ;;
            --help|-h)     show_help ;;
            *) die "Unknown option: $1. Run: incusbox build --help" ;;
        esac
    done

    [ -n "${ALIAS_NAME}" ] || die "--name is required"

    if [ -n "${SCRIPT_PATH}" ] && [ ! -f "${SCRIPT_PATH}" ]; then
        die "Script not found: ${SCRIPT_PATH}"
    fi

    # Derive a safe build container name from the alias
    BUILD_CT="incusbox-build-$(echo "${ALIAS_NAME}" | tr '/' '-' | tr -cd '[:alnum:]-')-$$"
}

# ── cleanup ───────────────────────────────────────────────────────────────────

_cleanup() {
    if [ "${KEEP}" -eq 0 ] && [ -n "${BUILD_CT}" ]; then
        if incus info "${BUILD_CT}" &>/dev/null 2>&1; then
            log "Removing build container: ${BUILD_CT}"
            incus delete --force "${BUILD_CT}" 2>/dev/null || true
        fi
    fi
}
trap _cleanup EXIT INT TERM

# ── build steps ───────────────────────────────────────────────────────────────

step_launch() {
    log "Launching build container '${BUILD_CT}' from ${BASE_IMAGE}..."

    local launch_args=("incus" "launch" "${BASE_IMAGE}" "${BUILD_CT}")

    [ -n "${PROFILE}" ]      && launch_args+=("--profile" "${PROFILE}")
    [ -n "${STORAGE_POOL}" ] && launch_args+=("--storage" "${STORAGE_POOL}")

    "${launch_args[@]}"

    # Wait for the container to be ready (cloud-init or basic networking)
    log "Waiting for container to be ready..."
    local retries=30
    while [ "$retries" -gt 0 ]; do
        if incus exec "${BUILD_CT}" -- true &>/dev/null 2>&1; then
            break
        fi
        sleep 2
        retries=$((retries - 1))
    done
    [ "$retries" -gt 0 ] || die "Container '${BUILD_CT}' did not become ready in time"
    log "Container ready."
}

step_packages() {
    [ -z "${PACKAGES}" ] && return 0

    log "Installing packages: ${PACKAGES}"
    # Detect package manager
    if incus exec "${BUILD_CT}" -- command -v apt-get &>/dev/null 2>&1; then
        incus exec "${BUILD_CT}" -- bash -c \
            "DEBIAN_FRONTEND=noninteractive apt-get update -qq && \
             apt-get install -y --no-install-recommends ${PACKAGES}"
    elif incus exec "${BUILD_CT}" -- command -v dnf &>/dev/null 2>&1; then
        incus exec "${BUILD_CT}" -- dnf install -y ${PACKAGES}
    elif incus exec "${BUILD_CT}" -- command -v pacman &>/dev/null 2>&1; then
        incus exec "${BUILD_CT}" -- pacman -Sy --noconfirm ${PACKAGES}
    elif incus exec "${BUILD_CT}" -- command -v apk &>/dev/null 2>&1; then
        incus exec "${BUILD_CT}" -- apk add --no-cache ${PACKAGES}
    else
        warn "Could not detect package manager — skipping package install"
    fi
}

step_script() {
    [ -z "${SCRIPT_PATH}" ] && return 0

    log "Running provisioning script: ${SCRIPT_PATH}"
    local remote_path="/tmp/incusbox-provision-$$.sh"
    incus file push "${SCRIPT_PATH}" "${BUILD_CT}${remote_path}"
    incus exec "${BUILD_CT}" -- chmod +x "${remote_path}"
    incus exec "${BUILD_CT}" -- bash "${remote_path}"
    incus exec "${BUILD_CT}" -- rm -f "${remote_path}"
}

step_cleanup_container() {
    log "Cleaning up container before publishing..."
    # Remove apt caches, logs, machine-id so the image is clean
    incus exec "${BUILD_CT}" -- bash -c '
        command -v apt-get &>/dev/null && apt-get clean && rm -rf /var/lib/apt/lists/* || true
        rm -f /etc/machine-id /var/lib/dbus/machine-id || true
        truncate -s 0 /var/log/syslog /var/log/auth.log 2>/dev/null || true
        rm -rf /tmp/* /var/tmp/* 2>/dev/null || true
        sync
    ' 2>/dev/null || true
}

step_stop() {
    log "Stopping build container..."
    incus stop "${BUILD_CT}"
}

step_publish() {
    [ "${NO_PUBLISH}" -eq 1 ] && return 0

    log "Publishing as image alias '${ALIAS_NAME}'..."

    local publish_args=("incus" "publish" "${BUILD_CT}" "--alias" "${ALIAS_NAME}")
    [ -n "${DESCRIPTION}" ] && publish_args+=("description=${DESCRIPTION}")

    "${publish_args[@]}"
    log "Published: ${ALIAS_NAME}"
    log "Create containers with: incusbox create --image ${ALIAS_NAME} --name <name>"
}

# ── main ──────────────────────────────────────────────────────────────────────

main() {
    parse_args "$@"

    bold "incusbox build"
    log "  Base image  : ${BASE_IMAGE}"
    log "  Alias       : ${ALIAS_NAME}"
    [ -n "${PACKAGES}" ]    && log "  Packages    : ${PACKAGES}"
    [ -n "${SCRIPT_PATH}" ] && log "  Script      : ${SCRIPT_PATH}"
    [ -n "${PROFILE}" ]     && log "  Profile     : ${PROFILE}"
    [ -n "${DESCRIPTION}" ] && log "  Description : ${DESCRIPTION}"
    echo ""

    step_launch
    step_packages
    step_script
    step_cleanup_container
    step_stop
    step_publish

    echo ""
    if [ "${NO_PUBLISH}" -eq 0 ]; then
        ok "Build complete. Image published as: ${ALIAS_NAME}"
    else
        ok "Build complete (--no-publish: container '${BUILD_CT}' not published)"
        [ "${KEEP}" -eq 1 ] && log "Container kept: ${BUILD_CT}"
    fi
}

main "$@"
