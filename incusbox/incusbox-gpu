#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-only
# incusbox-gpu: manage GPU passthrough for incusbox containers.

set -euo pipefail

# ── shared library ────────────────────────────────────────────────────────────
_lib="$(cd "$(dirname "$0")" && pwd)/lib.sh"
[ -f "${_lib}" ] || _lib="/usr/share/incusbox/lib.sh"
# shellcheck source=lib.sh disable=SC1091
. "${_lib}"

resolve_incus

show_help() {
    cat <<EOF
incusbox-gpu — manage GPU passthrough for containers

Usage:
  incusbox-gpu list-host              List GPUs available on the host
  incusbox-gpu attach  NAME [options] Attach a GPU to a container
  incusbox-gpu detach  NAME DEV_NAME  Remove a GPU from a container
  incusbox-gpu list    NAME           List GPUs attached to a container
  incusbox-gpu status  NAME           Show GPU status for a container

Attach options:
  --type physical|mdev|mig|virtio   GPU type (default: physical)
  --pci ADDR                        PCI address (e.g. 0000:01:00.0)
  --dev-name NAME                   Device name (default: gpu0)
  --vendor VENDOR                   GPU vendor filter (e.g. nvidia, amd, intel)

Options:
  -h, --help    Show this help

Examples:
  incusbox gpu list-host
  incusbox gpu attach  mybox
  incusbox gpu attach  mybox --pci 0000:01:00.0 --type physical
  incusbox gpu list    mybox
  incusbox gpu detach  mybox gpu0
  incusbox gpu status  mybox
EOF
}

# ── list-host ─────────────────────────────────────────────────────────────────

cmd_list_host() {
    log "GPUs available on host:"
    echo ""

    if ${INCUS} info --resources >/dev/null 2>&1; then
        ${INCUS} info --resources 2>/dev/null | awk '
            /^  GPUs:/,/^  [A-Z][a-z]/ {
                if (!/^  GPUs:/ && !/^  [A-Z][a-z]/) print "  " $0
            }
        '
    else
        warn "Could not retrieve GPU info from incus"
    fi

    echo ""
    if command -v lspci >/dev/null 2>&1; then
        info "PCI GPU devices:"
        lspci 2>/dev/null | grep -iE "VGA|3D|Display|NVIDIA|AMD|Intel.*Graphics" \
        | sed 's/^/  /' || info "  None found"
    fi
}

# ── attach ────────────────────────────────────────────────────────────────────

cmd_attach() {
    local name="$1"
    [ -z "${name}" ] && { show_help; exit 1; }
    shift

    local gpu_type="physical"
    local pci_addr=""
    local dev_name="gpu0"
    local vendor=""

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --type)     gpu_type="$2"; shift 2 ;;
            --pci)      pci_addr="$2"; shift 2 ;;
            --dev-name) dev_name="$2"; shift 2 ;;
            --vendor)   vendor="$2";   shift 2 ;;
            *) die "Unknown option: $1" ;;
        esac
    done

    require_incus

    local device_args=("${name}" "${dev_name}" gpu "gputype=${gpu_type}")
    [ -n "${pci_addr}" ] && device_args+=("pci=${pci_addr}")
    [ -n "${vendor}" ]   && device_args+=("vendorid=${vendor}")

    log "Attaching GPU to '${name}' (type=${gpu_type}${pci_addr:+, pci=${pci_addr}})"
    ${INCUS} config device add "${device_args[@]}"
    log "GPU attached: ${dev_name} → ${name}"
    log "  Type : ${gpu_type}"
    [ -n "${pci_addr}" ] && log "  PCI  : ${pci_addr}"
}

# ── detach ────────────────────────────────────────────────────────────────────

cmd_detach() {
    local name="$1"
    local dev_name="$2"
    [ -z "${name}" ] || [ -z "${dev_name}" ] && { show_help; exit 1; }
    require_incus

    ${INCUS} config device remove "${name}" "${dev_name}"
    log "GPU removed: ${dev_name} from '${name}'"
}

# ── list ──────────────────────────────────────────────────────────────────────

cmd_list() {
    local name="$1"
    [ -z "${name}" ] && { show_help; exit 1; }
    require_incus

    log "GPUs attached to '${name}':"
    echo ""
    printf "  %-20s %-12s %s\n" "DEVICE" "TYPE" "PCI"
    printf "  %-20s %-12s %s\n" "------" "----" "---"

    local found=false
    while IFS= read -r dev; do
        [ -n "${dev}" ] || continue
        local gtype pci
        gtype=$(${INCUS} config device get "${name}" "${dev}" gputype  2>/dev/null || echo "physical")
        pci=$(${INCUS} config device get   "${name}" "${dev}" pci      2>/dev/null || echo "")
        found=true
        printf "  %-20s %-12s %s\n" "${dev}" "${gtype}" "${pci}"
    done < <(${INCUS} config device list "${name}" 2>/dev/null \
             | grep "gpu" | awk '{print $1}' || true)

    if ! ${found}; then
        info "  No GPU devices attached"
    fi
}

# ── status ────────────────────────────────────────────────────────────────────

cmd_status() {
    local name="$1"
    [ -z "${name}" ] && { show_help; exit 1; }
    require_incus

    log "GPU status: ${name}"
    echo ""

    # Attached GPU devices
    cmd_list "${name}"

    echo ""
    info "Host GPU resources:"
    ${INCUS} info --resources 2>/dev/null | awk '
        /^  GPUs:/,/^  [A-Z][a-z]/ {
            if (!/^  GPUs:/ && !/^  [A-Z][a-z]/) print "  " $0
        }
    ' || true
}

# ── dispatch ──────────────────────────────────────────────────────────────────

[ "$#" -eq 0 ] && { show_help; exit 0; }

subcmd="$1"; shift
case "${subcmd}" in
    list-host|host)   cmd_list_host ;;
    attach|add)       cmd_attach "$@" ;;
    detach|remove|rm) cmd_detach "$@" ;;
    list|ls)          cmd_list   "$@" ;;
    status)           cmd_status "$@" ;;
    -h|--help|help)   show_help ;;
    *)
        printf >&2 "incusbox-gpu: unknown subcommand '%s'\n" "${subcmd}"
        printf >&2 "Run 'incusbox-gpu --help' for usage.\n"
        exit 1 ;;
esac
